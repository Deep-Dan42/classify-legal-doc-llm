# ============================================
# automacao-juridica-trf1 — Configuracao
# ============================================
# Copie este arquivo para .env e preencha com seus valores reais.
# O instalar.bat fara isso automaticamente, pedindo apenas a chave OpenAI.
# NUNCA commite o .env no repositorio.

# ------------------------------------------
# Chave de API (obrigatoria)
# ------------------------------------------
# OpenAI — usada para classificacao por LLM (GPT-4o-mini).
# Obtenha em: https://platform.openai.com/api-keys
# Formato: comeca com "sk-"
OPENAI_API_KEY=sk-...

# ------------------------------------------
# Extensao whom.doc9 (autenticacao TRF1 PJe)
# ------------------------------------------
# Caminho absoluto para a pasta da extensao whom.doc9 instalada no Chrome.
# Necessario apenas se a extensao nao estiver instalada no perfil do Chrome
# de automacao (data/navegador). Deixe em branco se a extensao ja foi
# instalada manualmente apos o primeiro download.
#
# Exemplo Windows: C:\Users\SeuNome\AppData\Local\Google\Chrome\User Data\Default\Extensions\lnidijeaekolpfeckelhkomndglcglhh\3.3.7_0
# Exemplo Mac: /Users/seunome/Library/Application Support/Google/Chrome/Default/Extensions/lnidijeaekolpfeckelhkomndglcglhh/3.3.7_0
WHOM_DOC9_EXTENSION_PATH=

# ------------------------------------------
# Perfil do navegador (persistent context)
# ------------------------------------------
# Pasta onde a sessao do Chrome de automacao e salva entre execucoes.
# Nao altere a menos que tenha motivo especifico.
BROWSER_PROFILE_DIR=data/navegador

# ------------------------------------------
# Extracao de texto — caracteres por tipo de documento
# ------------------------------------------
# Quantidade de caracteres extraidos do PDF para enviar ao classificador.
# Valores atuais ajustados para resultados de producao.
EXTRACT_CHARS_SENTENCA=1000
EXTRACT_CHARS_DECISAO=1000
EXTRACT_CHARS_PETICAO=6000

# ------------------------------------------
# Pipeline — configuracoes gerais
# ------------------------------------------
# Ano minimo do processo para ser considerado (filtro por numero CNJ).
MIN_PROCESS_YEAR=2016

# Numero maximo de tentativas por CNPJ em caso de falha.
MAX_ATTEMPTS_PER_CNPJ=3

# Pausa em segundos entre processamento de CNPJs.
PAUSE_BETWEEN_CNPJS_SECONDS=2.0

# ------------------------------------------
# Caminhos de dados
# ------------------------------------------
# Estes defaults funcionam sem alteracao.
DATA_ENTRADA_DIR=data/entrada
DATA_SAIDA_DIR=data/saida
DATA_DOCUMENTOS_DIR=data/documentos
DATA_EMBEDDINGS_DIR=data/embeddings
